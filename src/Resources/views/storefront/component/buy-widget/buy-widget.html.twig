{% sw_extends '@Storefront/storefront/component/buy-widget/buy-widget.html.twig' %}

{% block buy_widget_buy_form %}
    {{ parent() }}

    {% set tryOn = page.extensions.swag_try_on ?? null %}

    {% if tryOn %}
        <section class="swag-try-on-product-card mt-3">
            <div class="card border-0 bg-light">
                <div class="card-body">
                    <div class="d-flex flex-column flex-lg-row gap-3 align-items-lg-center justify-content-between">
                        <div>
                            <p class="text-uppercase small text-muted mb-1">Virtual try-on</p>
                            <h3 class="h5 mb-2">See it on your own hand</h3>
                            <p class="mb-0 text-muted">
                                Open the mobile camera experience for this {{ tryOn.wearMode }} and preview it live.
                            </p>
                        </div>

                        <div class="d-flex flex-column flex-sm-row gap-2">
                            <a class="btn btn-outline-primary"
                               href="{{ tryOn.mobileUrl }}"
                               target="_blank"
                               rel="noopener">
                                Open on phone
                            </a>
                            <button class="btn btn-primary"
                                    type="button"
                                    data-bs-toggle="modal"
                                    data-bs-target="#swagTryOnQrModal">
                                Show QR code
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <div class="modal fade" id="swagTryOnQrModal" tabindex="-1" aria-labelledby="swagTryOnQrModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h2 class="modal-title fs-5" id="swagTryOnQrModalLabel">Open virtual try-on on your phone</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body text-center">
                        <div class="d-inline-flex align-items-center justify-content-center border rounded p-2 bg-white mb-3"
                             data-swag-try-on-qrcode="true"
                             data-swag-try-on-qrcode-options='{{ {
                                 text: tryOn.mobileUrl,
                                 width: 240
                             }|json_encode }}'>
                        </div>

                        <p class="text-muted mb-2">
                            Scan this code with your phone, allow camera access, and position your {{ tryOn.wearMode == 'ring' ? 'finger' : 'wrist' }} in frame.
                        </p>

                        <a href="{{ tryOn.mobileUrl }}" class="btn btn-link">Direct mobile link</a>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}
