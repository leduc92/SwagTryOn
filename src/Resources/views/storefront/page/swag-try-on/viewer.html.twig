{% sw_extends '@Storefront/storefront/base.html.twig' %}

{% block base_main_inner %}
    <style>
        .swag-try-on-app {
            min-height: 100vh;
            background:
                radial-gradient(circle at top, rgba(255, 255, 255, 0.12), transparent 28%),
                linear-gradient(180deg, #08121f 0%, #0f2237 48%, #09131d 100%);
            color: #f8fbff;
        }

        .swag-try-on-shell {
            max-width: 1120px;
            margin: 0 auto;
            padding: 1rem;
        }

        .swag-try-on-related {
            margin-top: 1.25rem;
        }

        .swag-try-on-related-card {
            display: block;
            width: 100%;
            padding: 0;
            border: 0;
            background: transparent;
            text-align: left;
            color: inherit;
            text-decoration: none;
            cursor: pointer;
        }

        .swag-try-on-related-frame {
            overflow: hidden;
            border-radius: 1.25rem;
            background: rgba(6, 14, 24, 0.72);
            border: 1px solid rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(16px);
        }

        .swag-try-on-related-image {
            width: 100%;
            aspect-ratio: 1 / 1;
            object-fit: cover;
            display: block;
            background: #0d1620;
        }

        .swag-try-on-related-name {
            padding: 0.85rem 0.9rem 1rem;
            font-size: 0.95rem;
            line-height: 1.35;
            color: #f8fbff;
        }

        .swag-try-on-stage {
            position: relative;
            overflow: hidden;
            border-radius: 1.75rem;
            min-height: calc(100vh - 2rem);
            background: #050b12;
            box-shadow: 0 24px 80px rgba(0, 0, 0, 0.32);
        }

        .swag-try-on-viewport {
            position: relative;
            min-height: calc(100vh - 2rem);
            background:
                linear-gradient(180deg, rgba(6, 10, 15, 0.15) 0%, rgba(6, 10, 15, 0.68) 100%),
                #050b12;
        }

        .swag-try-on-video,
        .swag-try-on-canvas {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .swag-try-on-panel {
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: calc(100vh - 2rem);
            padding: 1rem;
            pointer-events: none;
        }

        .swag-try-on-controls,
        .swag-try-on-topbar,
        .swag-try-on-drawer {
            pointer-events: auto;
        }

        .swag-try-on-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.55rem 0.85rem;
            border-radius: 999px;
            background: rgba(248, 251, 255, 0.12);
            backdrop-filter: blur(16px);
            font-size: 0.875rem;
        }

        .swag-try-on-status-card,
        .swag-try-on-drawer {
            background: rgba(6, 14, 24, 0.72);
            border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(16px);
        }

        .swag-try-on-status-card {
            border-radius: 1.25rem;
            padding: 1rem;
        }

        .swag-try-on-drawer {
            border-radius: 1.25rem;
            padding: 1rem;
        }

        .swag-try-on-guidance {
            color: rgba(248, 251, 255, 0.76);
            font-size: 0.95rem;
        }

        .swag-try-on-drawer[hidden] {
            display: none !important;
        }

        @media (min-width: 992px) {
            .swag-try-on-stage {
                min-height: 820px;
            }

            .swag-try-on-viewport,
            .swag-try-on-panel {
                min-height: 820px;
            }

            .swag-try-on-panel {
                width: min(34%, 360px);
                margin-left: auto;
            }
        }
    </style>

    <div class="swag-try-on-app" data-try-on-app>
        <div class="swag-try-on-shell">
            <div class="swag-try-on-stage">
                <div class="swag-try-on-viewport">
                    <video class="swag-try-on-video" autoplay playsinline muted data-try-on-video></video>
                    <canvas class="swag-try-on-canvas" data-try-on-canvas></canvas>

                    <div class="swag-try-on-panel">
                        <div class="swag-try-on-topbar d-flex justify-content-between align-items-start gap-2">
                            <div class="swag-try-on-chip">
                                <span data-try-on-product-mode>{{ tryOn.wearMode|capitalize }}</span>
                                <span class="opacity-75" data-try-on-product-name-chip>{{ product.translated.name }}</span>
                            </div>

                            <a class="btn btn-sm btn-light" href="{{ seoUrl('frontend.detail.page', { productId: product.id }) }}">
                                Back
                            </a>
                        </div>

                        <div class="swag-try-on-controls">
                            <div class="swag-try-on-status-card mb-3">
                                <p class="mb-0 small opacity-75" data-try-on-status>
                                    Preparing camera access.
                                </p>
                            </div>

                            <div class="d-grid gap-2 mb-3">
                                <button class="btn btn-primary btn-lg" type="button" data-try-on-start>
                                    Start camera
                                </button>
                                <button class="btn btn-outline-light" type="button" data-try-on-toggle-manual>
                                    Manual adjustment
                                </button>
                            </div>

                            <div class="swag-try-on-drawer" data-try-on-manual-panel hidden>
                                <h2 class="h6 mb-3">Manual adjustment</h2>
                                <p class="small opacity-75 mb-3">
                                    Best results come from a tightly cropped transparent PNG. For watches, upload center, left, and right angle assets.
                                </p>
                                <div class="mb-3">
                                    <label class="form-label" for="swagTryOnScale">Scale</label>
                                    <input id="swagTryOnScale" type="range" min="0.4" max="2.2" step="0.05" class="form-range" data-try-on-scale>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label" for="swagTryOnOffsetX">Offset X</label>
                                    <input id="swagTryOnOffsetX" type="range" min="-0.3" max="0.3" step="0.01" class="form-range" data-try-on-offset-x>
                                </div>
                                <div>
                                    <label class="form-label" for="swagTryOnOffsetY">Offset Y</label>
                                    <input id="swagTryOnOffsetY" type="range" min="-0.3" max="0.3" step="0.01" class="form-range" data-try-on-offset-y>
                                </div>
                            </div>
                        </div>
                    </div>

                    <img src="{{ tryOn.overlayImageUrl }}" alt="" class="d-none" data-try-on-overlay-image>
                </div>
            </div>

            {% if relatedProducts and relatedProducts.elements %}
                <section class="swag-try-on-related">
                    {% set sliderConfig = {
                        title: { value: 'More to try on' },
                        displayMode: { value: 'standard' },
                        boxLayout: { value: 'standard' },
                        verticalAlign: { value: null },
                        navigationArrows: { value: 'outside' },
                        rotate: { value: false },
                        autoplayTimeout: { value: 5000 },
                        speed: { value: 300 },
                        border: { value: false },
                        elMinWidth: { value: '180px' }
                    } %}
                    {% set hasNavigationArrows = true %}
                    {% set productSliderOptionsSlider = {
                        controls: true,
                        nav: false,
                        mouseDrag: true,
                        autoplay: false,
                        autoplayButtonOutput: false,
                        autoplayTimeout: 5000,
                        speed: 300,
                        ariaLive: true,
                        gutter: 20,
                        loop: false,
                        rewind: true
                    } %}
                    {% set productSliderOptions = {
                        productboxMinWidth: '180px',
                        slider: productSliderOptionsSlider
                    } %}

                    <div class="base-slider product-slider has-nav has-nav-outside"
                         data-product-slider="true"
                         data-product-slider-options="{{ productSliderOptions|json_encode }}"
                         role="region"
                         aria-label="More products to try on"
                         tabindex="0">
                        <div class="cms-element-title">
                            <p class="cms-element-title-paragraph">More to try on</p>
                        </div>

                        <div class="product-slider-container" data-product-slider-container="true">
                            {% for relatedProduct in relatedProducts.elements %}
                                <div class="product-slider-item">
                                    {% set relatedOverlayUrl = relatedProduct.customFields.swag_try_on_overlay_url ?? (relatedProduct.cover and relatedProduct.cover.media ? relatedProduct.cover.media.url : '') %}
                                    {% set relatedOverlayLeftUrl = relatedProduct.customFields.swag_try_on_overlay_left_url ?? relatedOverlayUrl %}
                                    {% set relatedOverlayRightUrl = relatedProduct.customFields.swag_try_on_overlay_right_url ?? relatedOverlayUrl %}
                                    {% set relatedWearMode = relatedProduct.customFields.swag_try_on_wear_mode ?? tryOn.wearMode %}
                                    {% set relatedScale = relatedProduct.customFields.swag_try_on_scale ?? 1 %}
                                    {% set relatedOffsetX = relatedProduct.customFields.swag_try_on_offset_x ?? 0 %}
                                    {% set relatedOffsetY = relatedProduct.customFields.swag_try_on_offset_y ?? 0 %}
                                    <button class="swag-try-on-related-card"
                                            type="button"
                                            data-try-on-product-switch="true"
                                            data-try-on-product-id="{{ relatedProduct.id }}"
                                            data-try-on-product-name="{{ relatedProduct.translated.name }}"
                                            data-try-on-product-mode="{{ relatedWearMode }}"
                                            data-try-on-product-overlay-center="{{ relatedOverlayUrl }}"
                                            data-try-on-product-overlay-left="{{ relatedOverlayLeftUrl }}"
                                            data-try-on-product-overlay-right="{{ relatedOverlayRightUrl }}"
                                            data-try-on-product-scale="{{ relatedScale }}"
                                            data-try-on-product-offset-x="{{ relatedOffsetX }}"
                                            data-try-on-product-offset-y="{{ relatedOffsetY }}"
                                            data-try-on-product-url="{{ path('storefront.swag.try.on.viewer', { productId: relatedProduct.id, autostart: 1 }) }}">
                                        <div class="swag-try-on-related-frame">
                                            {% if relatedProduct.cover and relatedProduct.cover.media %}
                                                <img
                                                    src="{{ relatedProduct.cover.media.url }}"
                                                    alt="{{ relatedProduct.translated.name }}"
                                                    class="swag-try-on-related-image"
                                                    loading="lazy">
                                            {% else %}
                                                <div class="swag-try-on-related-image"></div>
                                            {% endif %}

                                            <div class="swag-try-on-related-name">
                                                {{ relatedProduct.translated.name }}
                                            </div>
                                        </div>
                                    </button>
                                </div>
                            {% endfor %}
                        </div>

                        <div class="product-slider-controls-container">
                            <div class="base-slider-controls" data-product-slider-controls="true" role="navigation">
                                <button
                                    class="base-slider-controls-prev product-slider-controls-prev is-nav-prev-outside"
                                    aria-label="{{ 'general.previous'|trans|striptags }}">
                                    {% sw_icon 'arrow-head-left' %}
                                </button>
                                <button
                                    class="base-slider-controls-next product-slider-controls-next is-nav-next-outside"
                                    aria-label="{{ 'general.next'|trans|striptags }}">
                                    {% sw_icon 'arrow-head-right' %}
                                </button>
                            </div>
                        </div>
                    </div>
                </section>
            {% endif %}
        </div>
    </div>

    <script type="module">
        const config = {
            wearMode: {{ tryOn.wearMode|json_encode|raw }},
            overlayImageUrls: {{ tryOn.overlayImageUrls|json_encode|raw }},
            mediapipeBundleUrl: {{ tryOn.mediapipeBundleUrl|json_encode|raw }},
            mediapipeWasmRoot: {{ tryOn.mediapipeWasmRoot|json_encode|raw }},
            mediapipeHandModelUrl: {{ tryOn.mediapipeHandModelUrl|json_encode|raw }},
            scale: Number({{ tryOn.scale|default(1)|json_encode|raw }}),
            offsetX: Number({{ tryOn.offsetX|default(0)|json_encode|raw }}),
            offsetY: Number({{ tryOn.offsetY|default(0)|json_encode|raw }}),
        };

        const params = new URLSearchParams(window.location.search);
        const app = document.querySelector('[data-try-on-app]');
        const video = app?.querySelector('[data-try-on-video]');
        const canvas = app?.querySelector('[data-try-on-canvas]');
        const overlayImage = app?.querySelector('[data-try-on-overlay-image]');
        const status = app?.querySelector('[data-try-on-status]');
        const startButton = app?.querySelector('[data-try-on-start]');
        const toggleManualButton = app?.querySelector('[data-try-on-toggle-manual]');
        const manualPanel = app?.querySelector('[data-try-on-manual-panel]');
        const productNameHeading = app?.querySelector('[data-try-on-product-name-heading]');
        const productNameChip = app?.querySelector('[data-try-on-product-name-chip]');
        const productModeLabel = app?.querySelector('[data-try-on-product-mode]');
        const productSwitchButtons = app?.querySelectorAll('[data-try-on-product-switch]');
        const scaleInput = app?.querySelector('[data-try-on-scale]');
        const offsetXInput = app?.querySelector('[data-try-on-offset-x]');
        const offsetYInput = app?.querySelector('[data-try-on-offset-y]');

        const state = {
            stream: null,
            running: false,
            starting: false,
            handLandmarker: null,
            lastVideoTime: -1,
            rafId: null,
            smoothing: null,
            activeOverlayKey: 'center',
            manual: false,
            scale: Number.isFinite(config.scale) ? config.scale : 1,
            offsetX: Number.isFinite(config.offsetX) ? config.offsetX : 0,
            offsetY: Number.isFinite(config.offsetY) ? config.offsetY : 0,
        };

        if (!app || !video || !canvas || !overlayImage || !status || !startButton) {
            throw new Error('Try-on page is missing required DOM elements.');
        }

        const isMobile = window.matchMedia('(max-width: 991px)').matches;
        const isSecureContextReady = window.isSecureContext || ['localhost', '127.0.0.1'].includes(window.location.hostname);

        scaleInput.value = String(state.scale);
        offsetXInput.value = String(state.offsetX);
        offsetYInput.value = String(state.offsetY);

        scaleInput.addEventListener('input', (event) => {
            state.scale = Number(event.target.value);
        });

        offsetXInput.addEventListener('input', (event) => {
            state.offsetX = Number(event.target.value);
        });

        offsetYInput.addEventListener('input', (event) => {
            state.offsetY = Number(event.target.value);
        });

        toggleManualButton?.addEventListener('click', () => {
            state.manual = !state.manual;
            manualPanel.hidden = !state.manual;
            updateStatus(
                state.manual
                    ? 'Manual adjustment is open. Use the sliders to fine tune placement.'
                    : 'Manual adjustment hidden. Tracking remains active.'
            );
        });

        productSwitchButtons?.forEach((button) => {
            button.addEventListener('click', () => {
                const nextOverlayUrls = {
                    center: button.dataset.tryOnProductOverlayCenter || '',
                    left: button.dataset.tryOnProductOverlayLeft || button.dataset.tryOnProductOverlayCenter || '',
                    right: button.dataset.tryOnProductOverlayRight || button.dataset.tryOnProductOverlayCenter || '',
                };

                if (!nextOverlayUrls.center) {
                    updateStatus('This product is missing a try-on overlay image.');

                    return;
                }

                const nextName = button.dataset.tryOnProductName || '';
                const nextMode = normalizeWearMode(button.dataset.tryOnProductMode || config.wearMode);
                const nextScale = Number(button.dataset.tryOnProductScale || state.scale);
                const nextOffsetX = Number(button.dataset.tryOnProductOffsetX || state.offsetX);
                const nextOffsetY = Number(button.dataset.tryOnProductOffsetY || state.offsetY);
                const nextUrl = button.dataset.tryOnProductUrl || '';

                config.wearMode = nextMode;
                config.overlayImageUrls = nextOverlayUrls;
                state.scale = Number.isFinite(nextScale) ? nextScale : 1;
                state.offsetX = Number.isFinite(nextOffsetX) ? nextOffsetX : 0;
                state.offsetY = Number.isFinite(nextOffsetY) ? nextOffsetY : 0;
                state.smoothing = null;
                state.activeOverlayKey = 'center';
                overlayImage.src = nextOverlayUrls.center;

                if (productNameHeading) {
                    productNameHeading.textContent = nextName;
                }

                if (productNameChip) {
                    productNameChip.textContent = nextName;
                }

                if (productModeLabel) {
                    productModeLabel.textContent = capitalize(nextMode);
                }

                scaleInput.value = String(state.scale);
                offsetXInput.value = String(state.offsetX);
                offsetYInput.value = String(state.offsetY);

                if (nextUrl) {
                    window.history.replaceState({}, '', nextUrl);
                }

                updateStatus(`Switched to ${nextName}. Keep your hand in frame.`);
            });
        });

        startButton.addEventListener('click', async () => {
            await startTryOn(true);
        });

        window.addEventListener('resize', resizeCanvas, { passive: true });
        document.addEventListener('visibilitychange', () => {
            if (!document.hidden) {
                resizeCanvas();
            }
        });

        if (!isSecureContextReady) {
            updateStatus('Camera requires HTTPS on phones. Open this page over HTTPS and try again.');
        } else if (!navigator.mediaDevices?.getUserMedia) {
            updateStatus('This browser does not support camera access for the try-on experience.');
        } else {
            updateStatus('Opening camera...');

            const shouldAutostart = params.get('autostart') !== '0' || isMobile;
            if (shouldAutostart) {
                queueMicrotask(() => {
                    startTryOn(false).catch(() => {
                        // The button remains available for a user-initiated retry.
                    });
                });
            }
        }

        async function startTryOn(userInitiated) {
            if (state.running || state.starting) {
                return;
            }

            if (!isSecureContextReady) {
                updateStatus('Camera requires HTTPS on phones. Open this page over HTTPS and try again.');

                return;
            }

            if (!navigator.mediaDevices?.getUserMedia) {
                updateStatus('This browser does not support camera access.');

                return;
            }

            state.starting = true;
            startButton.disabled = true;
            updateStatus('Requesting camera access...');

            try {
                await startCamera();
                await setupHandTracking();

                state.running = true;
                updateStatus('Camera is live. Hold your hand steady in the frame.');
                renderLoop();
            } catch (error) {
                console.error(error);
                updateStatus(formatCameraError(error, userInitiated));
                startButton.disabled = false;
            } finally {
                state.starting = false;
            }
        }

        async function startCamera() {
            const preferredConstraints = {
                audio: false,
                video: {
                    facingMode: {
                        ideal: 'environment',
                    },
                    width: {
                        ideal: 1080,
                    },
                    height: {
                        ideal: 1920,
                    },
                },
            };

            const fallbackConstraints = {
                audio: false,
                video: true,
            };

            try {
                state.stream = await navigator.mediaDevices.getUserMedia(preferredConstraints);
            } catch (error) {
                state.stream = await navigator.mediaDevices.getUserMedia(fallbackConstraints);
            }

            video.srcObject = state.stream;
            video.setAttribute('playsinline', 'true');
            video.muted = true;
            await video.play();
            resizeCanvas();
        }

        async function setupHandTracking() {
            if (!config.mediapipeBundleUrl || !config.mediapipeWasmRoot || !config.mediapipeHandModelUrl) {
                updateStatus('Camera is live. MediaPipe is not configured, so manual placement is available.');

                return;
            }

            const visionModule = await import(config.mediapipeBundleUrl);
            const { FilesetResolver, HandLandmarker } = visionModule;
            const vision = await FilesetResolver.forVisionTasks(config.mediapipeWasmRoot);

            state.handLandmarker = await HandLandmarker.createFromOptions(vision, {
                baseOptions: {
                    modelAssetPath: config.mediapipeHandModelUrl,
                },
                runningMode: 'VIDEO',
                numHands: 1,
                minHandDetectionConfidence: 0.5,
                minHandPresenceConfidence: 0.5,
                minTrackingConfidence: 0.5,
            });
        }

        function resizeCanvas() {
            canvas.width = video.clientWidth || canvas.clientWidth || window.innerWidth;
            canvas.height = video.clientHeight || canvas.clientHeight || window.innerHeight;
        }

        function renderLoop() {
            if (!state.running) {
                return;
            }

            const context = canvas.getContext('2d');
            if (!context) {
                return;
            }

            context.clearRect(0, 0, canvas.width, canvas.height);

            const anchor = detectAnchor();
            if (anchor) {
                drawOverlay(context, anchor);
            } else if (state.manual) {
                drawOverlay(context, manualAnchor());
            }

            state.rafId = window.requestAnimationFrame(renderLoop);
        }

        function detectAnchor() {
            if (!state.handLandmarker || video.readyState < 2) {
                return state.manual ? manualAnchor() : null;
            }

            if (video.currentTime === state.lastVideoTime) {
                return state.smoothing ?? (state.manual ? manualAnchor() : null);
            }

            state.lastVideoTime = video.currentTime;
            const result = state.handLandmarker.detectForVideo(video, performance.now());
            const landmarks = result.landmarks?.[0];

            if (!landmarks || landmarks.length < 21) {
                updateStatus(state.manual
                    ? 'No hand detected. Manual overlay is active.'
                    : 'Looking for a hand. Keep it centered and well lit.');

                return state.manual ? manualAnchor() : null;
            }

            const target = config.wearMode === 'ring'
                ? anchorForRing(landmarks)
                : anchorForWatch(landmarks);

            updateOverlayAsset(target.rotation);
            state.smoothing = smoothAnchor(target);
            updateStatus(state.manual
                ? 'Hand detected. Manual controls are available.'
                : 'Hand detected. Overlay is following your hand.');

            return state.smoothing;
        }

        function anchorForWatch(landmarks) {
            const wrist = landmarks[0];
            const middleBase = landmarks[9];
            const indexBase = landmarks[5];
            const pinkyBase = landmarks[17];
            const palmWidth = distance(indexBase, pinkyBase);
            const forearmLength = distance(wrist, middleBase);
            const width = Math.max(palmWidth * 1.15, forearmLength * 0.9);
            const angle = Math.atan2(indexBase.y - pinkyBase.y, indexBase.x - pinkyBase.x);
            const palmCenterX = (indexBase.x + pinkyBase.x) / 2;
            const palmCenterY = (indexBase.y + pinkyBase.y) / 2;
            const anchorX = lerp(wrist.x, palmCenterX, 0.28);
            const anchorY = lerp(wrist.y, palmCenterY, 0.28);

            return {
                x: anchorX + state.offsetX,
                y: anchorY + state.offsetY,
                width,
                height: width * 0.72,
                rotation: angle,
            };
        }

        function anchorForRing(landmarks) {
            const lowerKnuckle = landmarks[13];
            const upperKnuckle = landmarks[14];
            const width = distance(lowerKnuckle, upperKnuckle) * 1.9;
            const angle = Math.atan2(upperKnuckle.y - lowerKnuckle.y, upperKnuckle.x - lowerKnuckle.x);

            return {
                x: (lowerKnuckle.x + upperKnuckle.x) / 2 + state.offsetX,
                y: (lowerKnuckle.y + upperKnuckle.y) / 2 + state.offsetY,
                width,
                height: width * 0.78,
                rotation: angle,
            };
        }

        function manualAnchor() {
            return {
                x: 0.5 + state.offsetX,
                y: 0.55 + state.offsetY,
                width: 0.28,
                height: 0.22,
                rotation: 0,
            };
        }

        function smoothAnchor(nextAnchor) {
            if (!state.smoothing) {
                return nextAnchor;
            }

            const alpha = 0.35;

            return {
                x: lerp(state.smoothing.x, nextAnchor.x, alpha),
                y: lerp(state.smoothing.y, nextAnchor.y, alpha),
                width: lerp(state.smoothing.width, nextAnchor.width, alpha),
                height: lerp(state.smoothing.height, nextAnchor.height, alpha),
                rotation: lerp(state.smoothing.rotation, nextAnchor.rotation, alpha),
            };
        }

        function drawOverlay(context, anchor) {
            if (!overlayImage.complete) {
                return;
            }

            const centerX = anchor.x * canvas.width;
            const centerY = anchor.y * canvas.height;
            const drawWidth = anchor.width * canvas.width * state.scale;
            const drawHeight = anchor.height * canvas.height * state.scale;

            context.save();
            context.translate(centerX, centerY);
            context.rotate(anchor.rotation);
            context.drawImage(overlayImage, -drawWidth / 2, -drawHeight / 2, drawWidth, drawHeight);
            context.restore();
        }

        function updateStatus(message) {
            status.textContent = message;
        }

        function updateOverlayAsset(rotation) {
            if (config.wearMode !== 'watch') {
                return;
            }

            const nextOverlayKey = rotation > 0.35
                ? 'left'
                : (rotation < -0.35 ? 'right' : 'center');

            if (state.activeOverlayKey === nextOverlayKey) {
                return;
            }

            const nextOverlayUrl = config.overlayImageUrls?.[nextOverlayKey] || config.overlayImageUrls?.center || '';
            if (!nextOverlayUrl) {
                return;
            }

            state.activeOverlayKey = nextOverlayKey;
            overlayImage.src = nextOverlayUrl;
        }

        function normalizeWearMode(value) {
            return value === 'ring' ? 'ring' : 'watch';
        }

        function capitalize(value) {
            return value.charAt(0).toUpperCase() + value.slice(1);
        }

        function formatCameraError(error, userInitiated) {
            if (!(error instanceof Error)) {
                return userInitiated
                    ? 'Unable to start the camera on this device.'
                    : 'Automatic camera start failed. Tap "Start camera" to try again.';
            }

            if (error.name === 'NotAllowedError' || error.name === 'PermissionDeniedError') {
                return userInitiated
                    ? 'Camera permission was denied. Allow camera access in the browser and try again.'
                    : 'Automatic camera start was blocked. Tap "Start camera" to grant permission.';
            }

            if (error.name === 'NotFoundError' || error.name === 'DevicesNotFoundError') {
                return 'No camera was found on this device.';
            }

            if (error.name === 'NotReadableError' || error.name === 'TrackStartError') {
                return 'The camera is busy in another app. Close other camera apps and try again.';
            }

            if (error.name === 'OverconstrainedError') {
                return 'The preferred camera was unavailable, and the fallback also failed.';
            }

            return userInitiated
                ? 'Unable to start the camera or hand tracking on this device.'
                : 'Automatic camera start failed. Tap "Start camera" to try again.';
        }

        function distance(a, b) {
            return Math.hypot(a.x - b.x, a.y - b.y);
        }

        function lerp(from, to, factor) {
            return from + ((to - from) * factor);
        }
    </script>
