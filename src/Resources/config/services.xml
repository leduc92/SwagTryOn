<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <defaults autowire="true" autoconfigure="true" public="false"/>

        <service id="Shopware\Core\Content\Product\SalesChannel\Detail\AbstractProductDetailRoute"
                 alias="Shopware\Core\Content\Product\SalesChannel\Detail\ProductDetailRoute"/>
        <service id="Shopware\Core\Content\Product\SalesChannel\Listing\AbstractProductListingRoute"
                 alias="Shopware\Core\Content\Product\SalesChannel\Listing\ProductListingRoute"/>

        <service id="Shopware\SwagTryOn\Service\TryOnProductConfigurator"/>

        <service id="Shopware\SwagTryOn\Subscriber\ProductPageTryOnSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Shopware\SwagTryOn\Storefront\Controller\TryOnController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
            <tag name="controller.service_arguments"/>
        </service>
    </services>
</container>
